#!/usr/bin/env tclsh

package require cmdline

### opts analyze
# parent analyze
set subcoms {ls detach pop clear get help -h}

if {[lsearch $subcoms [lindex $argv 0]] >= 0} {
    set subcom [lindex $argv 0]
    set argv [lrange $argv 1 end]
} else {
    set subcom detach
}

# show help and exit
if {$subcom == "help" || $subcom == "-h"} {
    puts stderr "Usage: $argv0 \[subcom] ...
subcommands:
	ls:		list detached files (id and original path)
	detach:		detach files (default)
	pop:		restore n most recent (default: 1); -c copy, -d delete
	get:		restore by id (id required); -c copy without consuming
	clear:		remove without restoring (id.. or -a; default: last)
	help:		show this help"

    exit 1
}

# child analyze
set opts_list {
    ls {
	usage "ls [opts]"
	opts {}
    }
    detach {
	usage "[detach] file.."
	opts {}
    }
    pop {
	usage "pop [-d] [-c] [n]"
	opts {
	    {d "delete without restoring"}
	    {c "copy to restore (keep in stash)"}
	}
    }
    clear {
	usage "clear [opts] [id..]"
	opts {
	    {a "clear all files"}
	}
    }
    get {
	usage "get [-c] id.."
	opts {
	    {c "copy to restore (keep in stash)"}
	}
    }
}

set opts [dict get [dict get $opts_list $subcom] opts]
set usage [dict get [dict get $opts_list $subcom] usage]

try {
    array set params [::cmdline::getoptions argv $opts $usage]
} trap {CMDLINE USAGE} {msg o} {
    puts stderr "$msg"
    exit 1
}

### init
set basepath [file normalize "~/.detach"]
set filepath "${basepath}/config.list"

if {![file exists $filepath]} {
    file mkdir [file dirname $filepath]
    set fp [open $filepath w+]
} else {
    set fp [open $filepath r]
}

set raw [read $fp]
close $fp
set config_list [list]
foreach line [split $raw \n] {
    set line [string trim $line]
    if {$line ne ""} {
	lappend config_list $line
    }
}
# Keep newest first (descending id) for ls visibility and stack-like pop
if {[llength $config_list] >= 2 && [dict get [lindex $config_list 0] id] < [dict get [lindex $config_list end] id]} {
    set config_list [lreverse $config_list]
}

### subcom
proc update_config {config_list} {
    global filepath

    set fp [open $filepath w]
    foreach config $config_list {
	# Write one line per config (no extra [list] so read-back parses as dict)
	puts $fp $config
    }
    close $fp
}

proc get_max_id {basepath config_list} {
    set max 0
    if {[llength $config_list] > 0 && ![catch {dict get [lindex $config_list 0] id} id]} {
	set max $id
    }
    if {[file isdirectory $basepath]} {
	foreach f [glob -nocomplain -directory $basepath *] {
	    if {[string is integer -strict [file tail $f]] && [file tail $f] > $max} {
		set max [file tail $f]
	    }
	}
    }
    return $max
}

proc detach {} {
    global argv basepath config_list

    set id_end [get_max_id $basepath $config_list]

    foreach file $argv {
	set id_end [expr {$id_end + 1}]

	# file move
	if {[catch {file rename $file "${basepath}/${id_end}"} err]} {
	    puts stderr $err
	    continue
	}

	# prepend so newest is first (stack order)
	set config_list [linsert $config_list 0 [list id $id_end org [file normalize $file]]]
    }

    update_config $config_list
}

proc find_config {&config_list id} {
    upvar ${&config_list} config_list

    set i -1
    foreach config $config_list {
	incr i
	if {$id != [dict get $config id]} continue;
	return [list index $i config $config]
    }
}

proc pop {} {
    global argv basepath config_list params

    if {[llength $config_list] < 1} {
	puts stderr "detached data is not exists."
	exit 1
    }

    set n 1
    if {[llength $argv] >= 1} {
	if {![string is integer -strict [lindex $argv 0]] || [lindex $argv 0] < 1} {
	    puts stderr "pop: n must be a positive integer."
	    exit 1
	}
	set n [lindex $argv 0]
    }
    if {$n > [llength $config_list]} {
	set n [llength $config_list]
    }

    set delete_only 0
    if {[info exists params(d)] && $params(d)} { set delete_only 1 }
    set copy_only 0
    if {[info exists params(c)] && $params(c)} { set copy_only 1 }

    # Pop first n (newest first); remove from high index to low (unless -c)
    set to_pop [lrange $config_list 0 [expr {$n - 1}]]
    for {set i [expr {$n - 1}]} {$i >= 0} {incr i -1} {
	set config [lindex $to_pop $i]
	set id [dict get $config id]
	set from "${basepath}/${id}"
	if {$delete_only} {
	    if {[catch {file delete -force $from} err]} {
		puts stderr $err
		continue
	    }
	} elseif {$copy_only} {
	    set to [dict get $config org]
	    if {[catch {file copy -force $from $to} err]} {
		puts stderr $err
		continue
	    }
	    # don't remove from config_list
	    continue
	} else {
	    set to [dict get $config org]
	    if {[catch {file rename $from $to} err]} {
		puts stderr $err
		continue
	    }
	}
	set config_list [lreplace $config_list $i $i]
    }
    if {!$copy_only} { update_config $config_list }
}

proc get {} {
    global argv basepath config_list params

    if {[llength $config_list] < 1} {
	puts stderr "detached data is not exists."
	exit 1
    }
    if {[llength $argv] < 1} {
	puts stderr "get requires at least one id."
	exit 1
    }

    set copy_only 0
    if {[info exists params(c)] && $params(c)} { set copy_only 1 }

    set to_remove [list]
    foreach id $argv {
	set config_info [find_config config_list $id]
	if {$config_info == ""} {
	    puts stderr "ID $id is not found."
	    continue
	}

	set config [dict get $config_info config]
	set from "${basepath}/${id}"
	set to [dict get $config org]

	if {$copy_only} {
	    if {[catch {file copy -force $from $to} err]} {
		puts stderr $err
		continue
	    }
	} else {
	    if {[catch {file rename $from $to} err]} {
		puts stderr $err
		continue
	    }
	    set delid [dict get $config_info index]
	    lappend to_remove $delid
	}
    }
    # Remove in descending index order so indices stay valid
    foreach delid [lsort -integer -decreasing $to_remove] {
	set config_list [lreplace $config_list $delid $delid]
    }
    if {[llength $to_remove] > 0} { update_config $config_list }
}

proc clear {} {
    global argv basepath config_list params

    if {$params(a)} {
	set id_list [lmap config $config_list {dict get $config id}]
    } elseif {[llength $argv] < 1} {
	set id_list [dict get [lindex $config_list 0] id]
    } else {
	set id_list $argv
    }

    foreach id $id_list {
	set config_info [find_config config_list $id]
	if {$config_info == ""} {
	    puts stderr "ID $id is not found."
	    continue
	}

	set config [dict get $config_info config]
	set file "${basepath}/${id}"

	if {[catch {file delete -force $file} err]} {
	    puts stderr $err
	    continue
	}

	# update
	set delid [dict get $config_info index]
	set config_list [lreplace $config_list $delid $delid]
    }

    update_config $config_list
}

### run
switch $subcom {
    detach detach
    ls {
	foreach config $config_list {
	    puts "[dict get $config id] [dict get $config org]"
	}
    }
    pop pop
    get get
    clear clear
}
